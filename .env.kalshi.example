# Copy to .env.kalshi (do not commit real secrets)
# Fill these in before attempting live trading.
# Usage: set -a && source .env.kalshi && set +a

KALSHI_API_KEY=YOUR_KALSHI_API_KEY_HERE
KALSHI_API_SECRET=YOUR_KALSHI_API_SECRET_HERE

# Optional alternate endpoint if needed by your Kalshi account / environment.
# KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
