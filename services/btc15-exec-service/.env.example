NODE_ENV=development
MODE=paper
SERVICE_MODE=paper
LOG_LEVEL=info
HEALTH_PORT=3000
BINANCE_SYMBOL=btcusdt
PRICE_BUFFER_SIZE=60
SLOPE_LOOKBACK_SEC=10
ACCEL_LOOKBACK_SEC=5
VOL_LOOKBACK_SEC=30
ENTRY_PRICE_MIN_CENTS=58
ENTRY_PRICE_MAX_CENTS=65
TAKE_PROFIT_DOLLARS=10
STOP_LOSS_DOLLARS=15
FORCE_EXIT_REMAINING_SEC=180
KALSHI_ENV=demo
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_MARKET_PREFIX=KXBTCD-
KALSHI_MARKET_ALLOWLIST=
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
LIVE_TRADING_ENABLED=false
LIVE_CONFIRMATION_PHRASE=
EMERGENCY_STOP=false
PAPER_DEFAULT_SIZE=10
MAX_ORDER_NOTIONAL_DOLLARS=25
MAX_DAILY_LOSS_DOLLARS=25
MAX_OPEN_POSITIONS=1
EVAL_INTERVAL_MS=1000
MIN_PRICE_SAMPLES=5
BINANCE_RECONNECT_BASE_MS=1000
BINANCE_RECONNECT_MAX_MS=15000
BINANCE_STALE_THRESHOLD_MS=20000
